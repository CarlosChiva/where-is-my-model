# ------------------------------------------------------------------
# backend/.env.example
# ------------------------------------------------------------------
# Copy this file to .env.development and fill in the required values.
#   cp backend/.env.example backend/.env.development
# Do NOT commit .env.development with real secrets.
# ------------------------------------------------------------------

# Node environment (development | production)
NODE_ENV=development

# HTTP listening port (inside container)
PORT=8080

# MongoDB connection string
# Docker Compose: mongodb://mongo:27017/where-is-my-model
# Local dev:      mongodb://localhost:27017/where-is-my-model
MONGODB_URI=mongodb://mongo:27017/where-is-my-model

# Comma-separated list of allowed CORS origins
CLIENT_URL=http://localhost:3000

# JWT signing secret — MUST be at least 64 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# JWT token lifetime (e.g., 1h, 1d, 7d)
JWT_EXPIRES_IN=1d
# ------------------------------------------------------------------
# backend/.env.example
# ------------------------------------------------------------------
# Copy this file to .env.development and fill in the required values.
#   cp backend/.env.example backend/.env.development
# Do NOT commit .env.development with real secrets.
# ------------------------------------------------------------------

# Node environment (development | production)
NODE_ENV=development

# HTTP listening port (inside container)
PORT=8080

# MongoDB connection components
# Docker Compose defaults: host=mongo, port=27017
# Local dev defaults:      host=localhost, port=27017
# Leave MONGODB_USERNAME / MONGODB_PASSWORD empty for local dev without auth
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_DATABASE=where-is-my-model
MONGODB_USERNAME=admin
MONGODB_PASSWORD=changeme_dev_password

# Comma-separated list of allowed CORS origins
CLIENT_URL=https://localhost,http://localhost:3000

# ----- Access token (short-lived) ---------------------------------
# JWT signing secret for access tokens — MUST be at least 64 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# Access token lifetime (e.g., 15m, 30m, 1h)
JWT_EXPIRES_IN=15m

# ----- Refresh token (long-lived) ---------------------------------
# Separate secret for signing refresh tokens. MUST be at least 64 characters.
# Must NOT be the same value as JWT_SECRET.
# Generate with: openssl rand -base64 48
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_A_DIFFERENT_STRONG_SECRET

# Refresh token lifetime (e.g., 7d, 14d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# Health-check SSRF protection allowlist (optional)
# When set, outbound TCP/HTTP probes from healthChecker.js will ONLY
# connect to IPs falling within one of these CIDR ranges. If unset or
# empty, only the built-in denylist (loopback, private, link-local,
# etc.) is enforced and all other addresses are permitted.
# Example: allow only known production subnets
# HEALTH_CHECK_ALLOWED_NETWORKS=203.0.113.0/24,198.51.100.0/24
HEALTH_CHECK_ALLOWED_NETWORKS=

# ----- Initial admin seeding (optional) ----------------------------
# On first startup, if no users exist in the database, an admin user
# is created automatically from these two values. After the first admin
# exists, subsequent startups skip seeding silently.
#
# ⚠️  SECURITY WARNING: These values are SECRETS.
# - NEVER commit real credentials to version control.
# - In production, use strong, unique values for each deployment.
# - Rotate the initial password after first login and disable/disable seed.
# - For local development you may omit both variables (seeding is skipped).

ADMIN_USERNAME=changeme_admin_user
ADMIN_PASSWORD=CHANGE_ME_SET_A_STRONG_PASSWORD_HERE

# ----- Backup configuration (optional) ------------------------------
# Directory where mongodump creates timestamped backup folders.
# For production, mount this path to a persistent volume so backups
# survive container restarts. Default: /tmp/where-is-my-model-backups
BACKUP_DIR=/backups

# Number of daily backups to retain before automatic cleanup.
# Old backups beyond this threshold are deleted each run.
BACKUP_RETENTION_DAYS=7

# ----- Email verification (optional) ---------------------------------
# SMTP settings for sending email verification links during registration.
# If SMTP_HOST is unset, registration skips email sending but still generates
# tokens (useful for local dev with manual verification).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
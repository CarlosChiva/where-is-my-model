# ------------------------------------------------------------------
# Dependency artifacts — installed by Dockerfile during build
# ------------------------------------------------------------------

node_modules

# ------------------------------------------------------------------
# Build output — baked into image during build stage,
# not needed in development build context
# ------------------------------------------------------------------

dist

# ------------------------------------------------------------------
# Version control — not needed inside the container
# ------------------------------------------------------------------

.git

# ------------------------------------------------------------------
# Environment files — injected at runtime via docker-compose,
# not baked into the image (prevents credential leakage)
# ------------------------------------------------------------------

.env*

# ------------------------------------------------------------------
# Docker files — not needed inside the container
# ------------------------------------------------------------------

.dockerignore
Dockerfile

# ------------------------------------------------------------------
# Editor and OS artifacts
# ------------------------------------------------------------------

.DS_Store
*.swp
*.swo
*~

# ------------------------------------------------------------------
# IDE directories (optional — exclude if team uses shared configs)
# ------------------------------------------------------------------

.vscode/
.idea/
